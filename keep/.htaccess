RewriteCond %{HTTP_HOST} ^elitewasteghana.com$ [NC,OR]
RewriteCond %{HTTP_HOST} ^www.elitewasteghana.com$
RewriteCond %{REQUEST_URI} !public/
RewriteRule (.*) /public/$1 [L]

