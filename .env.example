APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Paystack — CUSTOMER profile (the install's customer, e.g. Elite Waste).
# Used for waste-collection invoice payments. Customer can also override these via Settings UI.
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Paystack — PROVIDER profile (you, the developer/service-provider).
# Used for platform billing (hosting/email/domain/SMS). Never exposed in UI — env only.
PAYSTACK_PROVIDER_PUBLIC_KEY=
PAYSTACK_PROVIDER_SECRET_KEY=

# MyCSMS v3 (SMS gateway)
MYCSMS_API_KEY=
MYCSMS_SENDER_ID=Elite Waste
MYCSMS_URL=https://app.mycsms.com/api/v3/sms/send
MYCSMS_MESSAGE_TYPE=text

# Domain locked onto user accounts provisioned through the customer-facing "Add Email" flow.
PLATFORM_EMAIL_DOMAIN=elitewasteghana.com

# Currency your provider Paystack account is allowed to charge in (USD-priced invoices auto-convert).
PLATFORM_PROVIDER_CHARGE_CURRENCY=GHS

# Live USD→GHS rate used at payment time. Update as your bank rate changes.
PLATFORM_USD_TO_GHS_RATE=15.5
